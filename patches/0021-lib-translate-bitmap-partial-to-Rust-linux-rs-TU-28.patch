+    bitmap2: *const c_ulong,
+    bits: c_uint,
+) -> c_uint {
+    // SAFETY: per function contract.
+    bitmap_weight_generic(bits as usize, |idx| unsafe {
+        let v = *bitmap1.add(idx) | *bitmap2.add(idx);
+        *dst.add(idx) = v;
+        v
+    })
+}
