+/// `dst = bitmap1 | bitmap2`; returns the popcount of `dst`, over `bits` bits.
+///
+/// # Safety
+/// `dst`/`bitmap1`/`bitmap2` each have at least `bits_to_longs(bits)`
+/// valid `usize`s.
+#[export]
+pub unsafe extern "C" fn __bitmap_weighted_or(
+    dst: *mut c_ulong,
