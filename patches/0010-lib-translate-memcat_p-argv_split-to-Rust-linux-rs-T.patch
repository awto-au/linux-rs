index 9279f082467d..67512bbc3692 100644
--- a/rust/helpers/slab.c
+++ b/rust/helpers/slab.c
@@ -15,3 +15,16 @@ rust_helper_kvrealloc_node_align(const void *p, size_t size, unsigned long align
 {
