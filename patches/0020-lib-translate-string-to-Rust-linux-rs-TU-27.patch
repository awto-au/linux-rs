+/// # Safety
+/// `addr` has at least `size` valid readable bytes.
+#[export]
+pub unsafe extern "C" fn memscan(addr: *mut c_void, c: c_int, mut size: usize) -> *mut c_void {
+    let mut p = addr.cast::<u8>();
+    let target = c as u8;
+    // SAFETY: per function contract.
+    unsafe {
+        while size != 0 {
+            if *p == target {
+                return p.cast();
+            }
+            p = p.add(1);
+            size -= 1;
+        }
+        p.cast()
+    }
