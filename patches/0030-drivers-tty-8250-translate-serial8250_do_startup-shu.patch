 drivers/tty/serial/8250/8250_port.c        | 369 +++++++++++++++++++++
 drivers/tty/serial/8250/8250_startup_rs.rs | 299 +++++++++++++++++
 drivers/tty/serial/8250/Kconfig            |  20 ++
 drivers/tty/serial/8250/Makefile           |   9 +
 4 files changed, 697 insertions(+)
