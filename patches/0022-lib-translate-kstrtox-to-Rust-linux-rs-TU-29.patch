+}
+
+/// # Safety
+/// `s` is a valid NUL-terminated C string; `res` is a valid `*mut i16`.
+#[export]
+pub unsafe extern "C" fn kstrtos16(s: *const c_char, base: c_uint, res: *mut i16) -> c_int {
+    let mut tmp: i64 = 0;
+    // SAFETY: per function contract.
